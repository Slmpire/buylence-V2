# Database
DATABASE_URL="postgresql://user:password@localhost:5432/buylence?schema=public"

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# Firebase Admin (from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Paystack
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""

# Rider claim timeout (minutes) — auto-release back to pool if not picked up
RIDER_CLAIM_TIMEOUT_MINUTES=15
